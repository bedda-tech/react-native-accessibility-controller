{
  "name": "react-native-accessibility-controller",
  "version": "0.1.0",
  "description": "Android AccessibilityService for React Native. Full read/write access to any app's UI tree, gestures, and system actions.",
  "main": "lib/commonjs/index.js",
  "module": "lib/typescript/index.js",
  "types": "lib/typescript/index.d.ts",
  "source": "src/index.ts",
  "files": [
    "src",
    "lib",
    "android",
    "!**/__tests__",
    "!**/__fixtures__",
    "!**/__mocks__"
  ],
  "scripts": {
    "build": "tsc && tsc --project tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "test": "jest",
    "clean": "rm -rf lib/"
  },
  "keywords": [
    "react-native",
    "accessibility",
    "accessibilityservice",
    "android",
    "automation",
    "ui-control",
    "turbomodule",
    "deft"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bedda-tech/react-native-accessibility-controller.git"
  },
  "author": "Bedda Tech <matt@bedda.tech> (https://bedda.tech)",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/bedda-tech/react-native-accessibility-controller/issues"
  },
  "homepage": "https://github.com/bedda-tech/react-native-accessibility-controller#readme",
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-native": ">=0.76.0"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/react": "^18.0.0",
    "jest": "^30.3.0",
    "react": "^18.0.0",
    "react-native": "^0.76.0",
    "ts-jest": "^29.4.9",
    "typescript": "^5.0.0"
  },
  "codegenConfig": {
    "name": "RNAccessibilityControllerSpec",
    "type": "modules",
    "jsSrcsDir": "src",
    "android": {
      "javaPackageName": "com.beddatech.accessibilitycontroller"
    }
  }
}
